CREATE TABLE IF NOT EXISTS featChoices (
    `id` INTEGER NOT NULL,
    `name` TEXT NOT NULL,
    `choose` INTEGER NOT NULL,
    owner TEXT,
    FOREIGN KEY (owner) REFERENCES users(id),
    PRIMARY KEY(id, owner)
);

insert:
INSERT OR REPLACE INTO featChoices (id, name, choose, owner) VALUES (?, ?, ?, ?);

delete:
DELETE FROM featChoices WHERE owner = :owner AND id = :id;

select:
SELECT * FROM featChoices WHERE id =:id AND (owner IS :owner OR owner IS NULL);