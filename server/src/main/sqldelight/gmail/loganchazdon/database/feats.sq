import com.google.gson.JsonArray;
import com.google.gson.JsonObject;


CREATE TABLE IF NOT EXISTS feats (
    `id` INTEGER NOT NULL,
    `name` TEXT NOT NULL,
    `desc` TEXT NOT NULL,
    `prerequisite` TEXT AS JsonObject,
    `abilityBonuses` TEXT AS JsonArray,
    `abilityBonusChoice` TEXT AS JsonObject,
    owner TEXT,
    FOREIGN KEY (owner) REFERENCES users(id),

    PRIMARY KEY(id, owner)
);

insert:
INSERT OR REPLACE INTO feats (id, name, desc, prerequisite, abilityBonuses, abilityBonusChoice, owner) VALUES (?, ?, ?, ?, ?, ?, ?);

delete:
DELETE FROM feats WHERE owner = :owner AND id =:id;

selectAllFor:
SELECT * FROM feats
WHERE (owner IS NULL OR owner = :owner);